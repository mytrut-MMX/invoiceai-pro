// ─── ACTION DROPDOWN ──────────────────────────────────────────────────────────
function ActionMenu({ quote, onEdit, onClone, onConvert, onPrint }) {
  const [open, setOpen] = useState(false);
  const ref = useRef(null);

  useEffect(() => {
    const handler = (e) => { if (ref.current && !ref.current.contains(e.target)) setOpen(false); };
    document.addEventListener("mousedown", handler);
    return () => document.removeEventListener("mousedown", handler);
  }, []);

  const items = [
    { label: "Edit", icon: <Ic.Edit />, action: () => { onEdit(quote); setOpen(false); } },
    { label: "Clone", icon: <Ic.Clone />, action: () => { onClone(quote); setOpen(false); } },
    { label: "Print / Download", icon: <Ic.Print />, action: () => { onPrint(quote); setOpen(false); } },
    ...(quote.status === "Accepted" ? [{ label: "Convert to Invoice", icon: <Ic.Invoice />, action: () => { onConvert(quote); setOpen(false); }, accent: true }] : []),
  ];

  return (
    <div ref={ref} style={{ position: "relative" }}>
      <button onClick={() => setOpen(!open)}
        style={{ padding: "6px 9px", border: "1.5px solid #E4E4E4", borderRadius: 7, background: "#fff", cursor: "pointer", color: "#555", display: "flex", alignItems: "center", fontFamily: ff, transition: "all 0.15s" }}
        onMouseEnter={e => e.currentTarget.style.borderColor = "#1A1A1A"}
        onMouseLeave={e => e.currentTarget.style.borderColor = "#E4E4E4"}>
        <Ic.More />
      </button>
      {open && (
        <div style={{ position: "absolute", right: 0, top: "calc(100% + 4px)", background: "#fff", border: "1.5px solid #EBEBEB", borderRadius: 10, boxShadow: "0 8px 24px rgba(0,0,0,0.10)", zIndex: 200, minWidth: 190, overflow: "hidden" }}>
          {items.map(item => (
            <button key={item.label} onClick={item.action}
              style={{ width: "100%", display: "flex", alignItems: "center", gap: 10, padding: "10px 14px", background: "none", border: "none", cursor: "pointer", fontFamily: ff, fontSize: 13, fontWeight: item.accent ? 700 : 400, color: item.accent ? "#E86C4A" : "#333", textAlign: "left", transition: "background 0.1s" }}
              onMouseEnter={e => e.currentTarget.style.background = "#F7F7F7"}
              onMouseLeave={e => e.currentTarget.style.background = "none"}>
              <span style={{ color: item.accent ? "#E86C4A" : "#888" }}>{item.icon}</span>{item.label}
            </button>
          ))}
        </div>
      )}
    </div>
  );
}

// ─── CONVERT TO INVOICE MODAL ─────────────────────────────────────────────────
