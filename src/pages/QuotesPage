        <Radio checked={prefs.autoConvert === "off"} onChange={() => onChange({ ...prefs, autoConvert: "off" })}
          label="Off — don't auto-convert" sublabel="Accepted quotes stay as quotes until you manually convert them." />
        <Radio checked={prefs.autoConvert === "draft"} onChange={() => onChange({ ...prefs, autoConvert: "draft" })}
          label="Create as Draft Invoice" sublabel="A draft invoice is automatically created. You review and send it manually." />
        <Radio checked={prefs.autoConvert === "send"} onChange={() => onChange({ ...prefs, autoConvert: "send" })}
          label="Create & Send Invoice immediately" sublabel="An invoice is created and marked Sent automatically when the quote is accepted." />
      </div>
    </div>
  );
}

// ─── QUOTE FORM ───────────────────────────────────────────────────────────────
function QuoteFormPage({ existing, quotes, onSave, onCancel, onConvert }) {
  const isEdit = !!existing;

  const [quoteNumber, setQuoteNumber] = useState(existing?.quote_number || nextQUO(quotes.map(q => q.quote_number)));
  const [customer, setCustomer] = useState(existing ? MOCK_CUSTOMERS.find(c => c.id === existing.customer_id) || null : null);
  const [issueDate, setIssueDate] = useState(existing?.issue_date || todayStr());
  const [expiryDate, setExpiryDate] = useState(existing?.expiry_date || addDaysStr(todayStr(), 30));
  const [status, setStatus] = useState(existing?.status || "Draft");
  const [currency, setCurrency] = useState(existing?.currency || "GBP");
  const [items, setItems] = useState(existing?.line_items?.length ? existing.line_items : [newLine(0)]);
  const [discountType, setDiscountType] = useState(existing?.discount_type || "percent");
  const [discountValue, setDiscountValue] = useState(existing?.discount_value || 0);
  const [shipping, setShipping] = useState(existing?.shipping || 0);
  const [notes, setNotes] = useState(existing?.notes || "");
  const [terms, setTerms] = useState(existing?.terms || DEFAULT_TERMS);
  const [prefs, setPrefs] = useState({
    allowEditing: existing?.allow_editing || false,
    hideZeroLines: existing?.hide_zero_lines || false,
    autoConvert: existing?.auto_convert || "off",
  });
  const [saving, setSaving] = useState(false);
  const [saveMsg, setSaveMsg] = useState("");
  const [activeTab, setActiveTab] = useState("form");
  const [showPrefs, setShowPrefs] = useState(false);
  const [showConvertModal, setShowConvertModal] = useState(false);
  const printRef = useRef(null);

  const currSymbol = CUR_SYM[currency] || "£";
  const subtotal = items.reduce((s, i) => s + Number(i.amount), 0);
  const discAmt = discountType === "percent" ? subtotal * (Number(discountValue) / 100) : Math.min(Number(discountValue), subtotal);
  const afterDiscount = subtotal - discAmt;
  const taxBreakdown = TAX_RATES.filter(r => r > 0).map(rate => ({
    rate, amount: items.filter(i => Number(i.tax_rate) === rate).reduce((s, i) => s + i.amount * (rate / 100), 0)
  })).filter(tb => tb.amount > 0);
  const taxTotal = taxBreakdown.reduce((s, tb) => s + tb.amount, 0);
  const total = afterDiscount + Number(shipping) + taxTotal;

  const previewData = { quoteNumber, customer, issueDate, expiryDate, items, subtotal, discAmt, shipping, taxBreakdown, total, notes, terms, currency, status, hideZero: prefs.hideZeroLines };

  const handleSave = useCallback(async (newStatus = status) => {
    setSaving(true);
    const payload = {
      quote_number: quoteNumber, customer_id: customer?.id || null,
      customer_name: customer?.name || "", customer_email: customer?.email || "",
      customer_address: customer?.address || "",
      issue_date: issueDate, expiry_date: expiryDate, status: newStatus, currency,
      subtotal, discount_type: discountType, discount_value: Number(discountValue),
      discount_amount: discAmt, shipping: Number(shipping), tax_total: taxTotal, total,
      notes, terms, hide_zero_lines: prefs.hideZeroLines,
      allow_editing: prefs.allowEditing, auto_convert: prefs.autoConvert,
      updated_at: new Date().toISOString(),
    };
    try {
      let saved;
      if (isEdit && existing.id) {
        await sbFetch("PATCH", `quotes?id=eq.${existing.id}`, payload);
        await sbFetch("DELETE", `quote_line_items?quote_id=eq.${existing.id}`);
        saved = { ...existing, ...payload };
      } else {
        const [q] = await sbFetch("POST", "quotes", payload);
        saved = q;
      }
      if (saved?.id) {
        await sbFetch("POST", "quote_line_items", items.map((item, idx) => ({
          quote_id: saved.id, description: item.description, quantity: Number(item.quantity),
          rate: Number(item.rate), tax_rate: Number(item.tax_rate), amount: Number(item.amount), sort_order: idx,
        })));
      }
      setStatus(newStatus);
      setSaveMsg("Saved!");
      onSave({ ...payload, id: saved?.id || existing?.id || crypto.randomUUID(), line_items: items, status: newStatus });
    } catch (err) {
      console.warn("Supabase not configured, saving locally:", err.message);
      setSaveMsg("Saved locally!");
      onSave({ ...payload, id: existing?.id || crypto.randomUUID(), line_items: items, status: newStatus });
    }
    setSaving(false);
    setTimeout(() => setSaveMsg(""), 3000);
  }, [quoteNumber, customer, issueDate, expiryDate, status, currency, items, discountType, discountValue, discAmt, shipping, taxTotal, total, notes, terms, prefs, isEdit, existing, onSave]);

  const expired = isExpired(expiryDate);

  return (
    <div style={{ fontFamily: ff }}>
      {/* Page header */}
      <div style={{ display: "flex", alignItems: "center", justifyContent: "space-between", marginBottom: 20 }}>
        <div>
          <h1 style={{ fontSize: 22, fontWeight: 800, color: "#1A1A1A", margin: "0 0 3px", letterSpacing: "-0.02em" }}>
            {isEdit ? `Edit ${quoteNumber}` : "New Quote"}
          </h1>
          <p style={{ color: "#AAA", fontSize: 13, margin: 0 }}>
            {expired && status !== "Accepted" ? <span style={{ color: "#DC2626", fontWeight: 600 }}>⚠ Expired {fmtDate(expiryDate)}</span> : isEdit ? `Last updated ${fmtDate(existing?.updated_at)}` : "Fill in the details below"}
          </p>
        </div>
        <div style={{ display: "flex", gap: 9, alignItems: "center" }}>
          {saveMsg && <span style={{ fontSize: 12, color: "#16A34A", fontWeight: 700, display: "flex", alignItems: "center", gap: 4 }}><Ic.Check />{saveMsg}</span>}
          {isEdit && status === "Accepted" && (
            <Btn onClick={() => setShowConvertModal(true)} variant="teal" icon={<Ic.Invoice />}>Convert to Invoice</Btn>
          )}
          <Btn onClick={onCancel} variant="outline">Cancel</Btn>
          <Btn onClick={() => handleSave("Draft")} variant="outline" disabled={saving} icon={<Ic.Save />}>Save Draft</Btn>
          <Btn onClick={() => handleSave("Sent")} variant="accent" disabled={saving} icon={<Ic.Send />}>{saving ? "Saving…" : "Save & Send"}</Btn>
        </div>
      </div>

      {/* Tab switcher */}
      <div style={{ display: "flex", gap: 3, background: "#F0F0F0", padding: 3, borderRadius: 9, marginBottom: 16, width: "fit-content" }}>
        {[["form", <Ic.Edit />, "Edit"], ["preview", <Ic.Eye />, "Preview"]].map(([t, icon, label]) => (
          <button key={t} onClick={() => setActiveTab(t)}
            style={{ display: "flex", alignItems: "center", gap: 6, padding: "7px 15px", borderRadius: 7, border: "none", background: activeTab === t ? "#1A1A1A" : "transparent", color: activeTab === t ? "#fff" : "#888", fontSize: 13, fontWeight: 600, cursor: "pointer", fontFamily: ff, transition: "all 0.15s" }}>
            {icon}{label}
          </button>
        ))}
      </div>

      {activeTab === "form" && (
        <div style={{ display: "grid", gridTemplateColumns: "minmax(0,1fr) 330px", gap: 18, alignItems: "start" }}>
          <div>
            {/* Quote Details */}
            <SectionCard title="Quote Details" subtitle="Reference number, dates and status">
              <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr 1fr", gap: 12 }}>
                <div><Label required>Quote Number</Label><Input value={quoteNumber} onChange={setQuoteNumber} placeholder="QUO-0001" /></div>
                <div><Label required>Issue Date</Label><Input value={issueDate} onChange={setIssueDate} type="date" /></div>
                <div><Label required>Expiry Date</Label><Input value={expiryDate} onChange={setExpiryDate} type="date" style={{ borderColor: expired ? "#FCA5A5" : undefined }} /></div>
              </div>
              <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 12, marginTop: 12 }}>
                <div><Label>Status</Label><Select value={status} onChange={setStatus} options={QUOTE_STATUSES} /></div>
                <div><Label>Currency</Label><Select value={currency} onChange={setCurrency} options={CURRENCIES_OPT} /></div>
              </div>
              {expired && status !== "Accepted" && (
                <div style={{ display: "flex", gap: 8, marginTop: 12, padding: "9px 12px", background: "#FEF2F2", borderRadius: 8, border: "1px solid #FECACA" }}>
                  <div style={{ color: "#DC2626" }}><Ic.Info /></div>
                  <p style={{ margin: 0, fontSize: 12, color: "#7F1D1D", lineHeight: 1.6 }}>This quote has expired. Consider updating the expiry date or cloning a fresh quote.</p>
                </div>
              )}
            </SectionCard>

            {/* Bill To */}
            <SectionCard title="Quote For" subtitle="Select the customer this quote is addressed to">
              <Select value={customer?.id || ""} onChange={id => setCustomer(MOCK_CUSTOMERS.find(c => c.id === id) || null)} options={MOCK_CUSTOMERS.map(c => ({ value: c.id, label: c.name }))} placeholder="Select a customer…" />
              {customer && (
                <div style={{ marginTop: 10, padding: "10px 13px", background: "#F9F9F9", borderRadius: 8, border: "1px solid #EBEBEB" }}>
                  <div style={{ fontSize: 13, fontWeight: 700, color: "#1A1A1A" }}>{customer.name}</div>
                  <div style={{ fontSize: 12, color: "#888", marginTop: 2 }}>{customer.email} · {customer.address}</div>
                </div>
              )}
            </SectionCard>

            {/* Line Items */}
            <SectionCard title="Line Items" subtitle="Products or services included in this quote">
              <LineItemsTable items={items} onChange={setItems} currSymbol={currSymbol} hideZero={prefs.hideZeroLines} />
              <div style={{ display: "flex", justifyContent: "flex-end", marginTop: 18 }}>
                <TotalsBlock subtotal={subtotal} discountType={discountType} discountValue={discountValue} setDiscountType={setDiscountType} setDiscountValue={setDiscountValue} shipping={shipping} setShipping={setShipping} taxBreakdown={taxBreakdown} total={total} currSymbol={currSymbol} />
              </div>
            </SectionCard>

            {/* Notes & Terms */}
            <SectionCard title="Notes & Terms">
              <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 14 }}>
                <div>
                  <Label>Customer Notes</Label>
                  <Textarea value={notes} onChange={setNotes} placeholder="Additional notes visible to the customer…" rows={4} />
                  <div style={{ fontSize: 10, color: "#CCC", marginTop: 3 }}>Visible on the printed quote</div>
                </div>
                <div>
                  <Label>Terms & Conditions</Label>
                  <Textarea value={terms} onChange={setTerms} placeholder="Validity, payment terms, etc." rows={4} />
                  <div style={{ fontSize: 10, color: "#CCC", marginTop: 3 }}>Printed at the bottom of the quote</div>
                </div>
              </div>
            </SectionCard>

            {/* More / Preferences */}
            <div style={{ background: "#fff", borderRadius: 12, border: "1px solid #EBEBEB", overflow: "hidden", marginBottom: 16 }}>
              <button onClick={() => setShowPrefs(!showPrefs)}
                style={{ width: "100%", display: "flex", alignItems: "center", justifyContent: "space-between", padding: "16px 22px", background: "none", border: "none", cursor: "pointer", fontFamily: ff }}>
                <div style={{ display: "flex", alignItems: "center", gap: 9 }}>
                  <div style={{ color: "#888" }}><Ic.Settings /></div>
                  <div>
                    <div style={{ fontSize: 13, fontWeight: 800, color: "#1A1A1A", textAlign: "left" }}>More / Preferences</div>
                    <div style={{ fontSize: 11, color: "#AAA", textAlign: "left", marginTop: 1 }}>
                      Auto-convert: <strong>{prefs.autoConvert}</strong> · Editing: <strong>{prefs.allowEditing ? "on" : "off"}</strong> · Zero lines: <strong>{prefs.hideZeroLines ? "hidden" : "shown"}</strong>
                    </div>
                  </div>
                </div>
                <span style={{ color: "#AAA", transform: showPrefs ? "rotate(180deg)" : "none", transition: "transform 0.2s" }}><Ic.ChevDown /></span>
              </button>
              {showPrefs && (
                <div style={{ padding: "0 22px 18px", borderTop: "1px solid #F5F5F5" }}>
                  <div style={{ height: 14 }} />
                  <PreferencesPanel prefs={prefs} onChange={setPrefs} />
                </div>
              )}
            </div>
          </div>

          {/* Live Preview */}
          <div style={{ position: "sticky", top: 20 }}>
            <div style={{ fontSize: 10, fontWeight: 700, color: "#AAA", textTransform: "uppercase", letterSpacing: "0.09em", marginBottom: 10 }}>Live Preview</div>
            <QuotePreview data={previewData} currSymbol={currSymbol} printRef={printRef} />
          </div>
        </div>
      )}

      {activeTab === "preview" && (
        <div style={{ maxWidth: 680, margin: "0 auto" }}>
          <div style={{ display: "flex", justifyContent: "flex-end", gap: 9, marginBottom: 12 }}>
            <Btn variant="outline" size="sm" icon={<Ic.Print />} onClick={() => window.print()}>Print</Btn>
            <Btn variant="outline" size="sm" icon={<Ic.Download />}>Download PDF</Btn>
            <Btn variant="primary" size="sm" icon={<Ic.Send />} onClick={() => handleSave("Sent")}>Send Quote</Btn>
          </div>
          <QuotePreview data={previewData} currSymbol={currSymbol} printRef={printRef} />
        </div>
      )}

      {showConvertModal && (
        <ConvertModal
          quote={{ ...existing, quote_number: quoteNumber, customer_name: customer?.name }}
          onClose={() => setShowConvertModal(false)}
          onConfirm={(mode) => { setShowConvertModal(false); onConvert({ ...existing, quote_number: quoteNumber, customer_name: customer?.name, customer_id: customer?.id, customer_email: customer?.email, customer_address: customer?.address, total }, mode); }}
        />
      )}
    </div>
  );
}

// ─── ROOT: QUOTES PAGE ────────────────────────────────────────────────────────
export default function QuotesPage({ onConvertToInvoice }) {
  const [quotes, setQuotes] = useState(MOCK_QUOTES_INITIAL);
  const [view, setView] = useState("list"); // list | new | edit
  const [editing, setEditing] = useState(null);
  const [convertTarget, setConvertTarget] = useState(null);
  const [printTarget, setPrintTarget] = useState(null);

  const handleSave = (q) => {
    setQuotes(prev => {
      const idx = prev.findIndex(x => x.id === q.id);
      if (idx >= 0) { const u = [...prev]; u[idx] = q; return u; }
      return [q, ...prev];
    });
    setView("list"); setEditing(null);
  };

  const handleClone = (q) => {
    const cloned = {
      ...q,
      id: crypto.randomUUID(),
      quote_number: nextQUO([...quotes.map(x => x.quote_number), q.quote_number]),
      status: "Draft",
      issue_date: todayStr(),
      expiry_date: addDaysStr(todayStr(), 30),
      converted_invoice_id: null,
    };
    setQuotes(prev => [cloned, ...prev]);
  };

  const handleConvert = (q, mode) => {
    // Mark quote as converted
    setQuotes(prev => prev.map(x => x.id === q.id ? { ...x, converted_invoice_id: "converted" } : x));
    // Notify parent (App.jsx) to create invoice
    onConvertToInvoice?.({ quote: q, mode });
    setView("list"); setEditing(null);
  };

  const handleConvertFromList = (q) => setConvertTarget(q);

  return (
    <div style={{ padding: "28px 32px", maxWidth: 1200, fontFamily: ff }}>
      <style>{`@import url('https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600;700;800&display=swap');`}</style>

      {view === "list" && (
        <>
          <div style={{ marginBottom: 22 }}>
            <h1 style={{ fontSize: 24, fontWeight: 800, color: "#1A1A1A", margin: "0 0 4px", letterSpacing: "-0.02em" }}>Quotes</h1>
            <p style={{ color: "#AAA", fontSize: 13, margin: 0 }}>Create, manage and send quotes to your customers</p>
          </div>
          <QuotesList
            quotes={quotes}
            onNew={() => { setEditing(null); setView("new"); }}
            onEdit={(q) => { setEditing(q); setView("edit"); }}
            onClone={handleClone}
            onConvert={handleConvertFromList}
            onPrint={(q) => setPrintTarget(q)}
          />
        </>
      )}

      {(view === "new" || view === "edit") && (
        <QuoteFormPage
          existing={view === "edit" ? editing : null}
          quotes={quotes}
          onSave={handleSave}
          onCancel={() => { setView("list"); setEditing(null); }}
          onConvert={(q, mode) => handleConvert(q, mode)}
        />
      )}

      {convertTarget && (
        <ConvertModal
          quote={convertTarget}
          onClose={() => setConvertTarget(null)}
          onConfirm={(mode) => { handleConvert(convertTarget, mode); setConvertTarget(null); }}
        />
      )}

      {printTarget && <PrintModal quote={printTarget} onClose={() => setPrintTarget(null)} />}
    </div>
  );
}
