{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "routes": [
    { "src": "/agent", "dest": "/agent.html" },
    { "src": "/demo", "dest": "/demo.html" },
    { "src": "/demo-construction", "dest": "/demo-construction.html" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
