{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [{ "source": "/api/(.*)", "destination": "/api/$1" }],
  "redirects": [
    {
      "source": "/:path*",
      "destination": "https://invoicesaga.com/:path*",
      "permanent": true,
      "has": [{ "type": "host", "value": "www.invoicesaga.com" }]
    }
  ]
}
